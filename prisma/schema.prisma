generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Certificate {
  id             String   @id @default(cuid())
  name           String
  branch         String
  cnpj           String   @default("")
  type           String   @default("")
  password       String
  installDate    DateTime
  expirationDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
